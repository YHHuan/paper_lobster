# ─────────── v2.5 (kept) ───────────

# OpenRouter (REMOTE tier — Sonnet for Connect step + high-quality writes)
OPENROUTER_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram
# TELEGRAM_BOT_TOKEN from @BotFather.
# Set exactly ONE of TELEGRAM_USER_ID / ALLOWED_USER_ID to your numeric
# Telegram user id — every command is gated behind this filter, so the
# bot will silently reject other users. TELEGRAM_CHAT_ID is where the
# bot pushes notifications (heartbeats, digests). For solo use all three
# can be the same value.
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
TELEGRAM_CHAT_ID=
ALLOWED_USER_ID=

# X (Twitter)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
TWITTER_HANDLE=
TWITTER_BEARER_TOKEN=

# Threads (Meta)
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_ENABLED=true

# Tavily
TAVILY_API_KEY=

# Optional model overrides
GEMINI_25_MODEL=google/gemini-2.5-pro-preview
GEMINI_3_MODEL=google/gemini-3
GEMINI_31_MODEL=google/gemini-3.1

# ─────────── v3 NEW ───────────

# LOCAL tier — OpenAI-compatible endpoint.
# Env vars override YAML (lobster/config/lobster.yaml local_endpoint /
# default_local_model). LOCAL_LLM_MAX_TOKENS_CAP caps the retry bump for
# reasoning models that blow through max_tokens mid-thought.
LOCAL_LLM_BASE_URL=http://103.124.75.231:5000/v1
LOCAL_LLM_MODEL=nemotron-super-1m
LOCAL_LLM_API_KEY=none
LOCAL_LLM_MAX_TOKENS=4096
LOCAL_LLM_MAX_TOKENS_CAP=12288

# Curiosity loop tuning
CURIOSITY_LOOP_MAX_ROUNDS_PER_DAY=10
CURIOSITY_LOOP_SLEEP_BETWEEN_ROUNDS=900
CONNECT_RATE_STALL_THRESHOLD=0.3
FORAGE_MAX_PER_SOURCE=3

# Knowledge state JSON mirror (optional — set to enable git-friendly snapshot)
KNOWLEDGE_STATE_PATH=data/knowledge_state.json

# ─────────── system ───────────

TZ=Asia/Taipei
MONTHLY_TOKEN_BUDGET=15
PROACTIVE_ENGAGEMENT_ENABLED=false

# DB connect behaviour. Unset/empty → strict (exit on first health check
# failure). ALLOW_DB_DEGRADED=1 → log and continue (only useful for local
# development without Supabase reachable).
ALLOW_DB_DEGRADED=

# Webhook (set on Railway, leave empty for local polling)
WEBHOOK_URL=
PORT=8000
